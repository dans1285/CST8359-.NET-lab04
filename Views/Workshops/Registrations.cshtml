@model List<Lab3WorkshopRsvp.Models.Rsvp>

@{
    ViewData["Title"] = "All Registrations";
}

<div class="container">
    <h2 class="mb-4">Workshop Registrations</h2>

    @if (Model != null && Model.Count > 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Total Registrations: <strong>@Model.Count</strong>
        </div>

        <div class="card shadow">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Full Name</th>
                                <th>Email</th>
                                <th>Workshop</th>
                                <th>Accommodation</th>
                                <th>Registration Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.Count; i++)
                            {
                                <tr>
                                    <td>@(i + 1)</td>
                                    <td>@Model[i].FullName</td>
                                    <td>@Model[i].Email</td>
                                    <td><strong>@Model[i].WorkshopTitle</strong></td>
                                    <td>
                                        @if (Model[i].NeedsAccommodation)
                                        {
                                            <span class="badge bg-info">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">No</span>
                                        }
                                    </td>
                                    <td>@Model[i].RegistrationDate.ToString("MM/dd/yyyy hh:mm tt")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning" role="alert">
            <h4 class="alert-heading">No Registrations Yet</h4>
            <p>There are currently no workshop registrations.</p>
            <hr>
            <p class="mb-0">
                <a asp-action="RsvpForm" class="btn btn-primary">
                    <i class="bi bi-pencil-square"></i> Register for a Workshop
                </a>
            </p>
        </div>
    }

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left"></i> Back to Home
        </a>
    </div>
</div>
