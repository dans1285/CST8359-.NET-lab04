@model Lab3WorkshopRsvp.Models.Rsvp

@{
    ViewData["Title"] = "Registration Confirmed";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="alert alert-success shadow" role="alert">
            <h4 class="alert-heading">
                <i class="bi bi-check-circle-fill"></i> Registration Confirmed!
            </h4>
            <p class="mb-0">@ViewData["Message"]</p>
        </div>

        <div class="card shadow mt-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Registration Details</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Full Name:</dt>
                    <dd class="col-sm-8">@Model.FullName</dd>

                    <dt class="col-sm-4">Email:</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4">Workshop:</dt>
                    <dd class="col-sm-8"><strong>@Model.WorkshopTitle</strong></dd>

                    <dt class="col-sm-4">Accommodation:</dt>
                    <dd class="col-sm-8">
                        @if (Model.NeedsAccommodation)
                        {
                            <span class="badge bg-info">Assistance Requested</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Not Required</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Registration Date:</dt>
                    <dd class="col-sm-8">@Model.RegistrationDate.ToString("MMMM dd, yyyy - hh:mm tt")</dd>
                </dl>

                <div class="alert alert-info mt-3" role="alert">
                    <i class="bi bi-envelope"></i> A confirmation email will be sent to <strong>@Model.Email</strong> shortly.
                </div>
            </div>
        </div>

        <div class="mt-4 d-grid gap-2 d-md-flex justify-content-md-between">
            <a asp-action="Index" class="btn btn-outline-primary">
                <i class="bi bi-house"></i> Back to Home
            </a>
            <a asp-action="Registrations" class="btn btn-primary">
                <i class="bi bi-list-ul"></i> View All Registrations
            </a>
        </div>
    </div>
</div>
